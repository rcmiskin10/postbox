{
  "name": "postbox",
  "version": "0.1.0",
  "description": "A mailbox for agent sessions: race-free, server-free task handoff via the Maildir atomic-rename pattern.",
  "type": "module",
  "bin": {
    "postbox": "bin/postbox.mjs"
  },
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "postbox": "node bin/postbox.mjs"
  },
  "keywords": [
    "orchestration",
    "handoff",
    "mailbox",
    "multi-agent",
    "maildir",
    "message-bus",
    "claude-code"
  ],
  "license": "MIT",
  "author": "Ricky Miskin",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "vitest": "^2.1.0"
  }
}
